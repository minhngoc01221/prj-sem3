generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// User model for authentication
model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  name      String?
  role      String   @default("admin")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// Model for Tourist Spots
model TouristSpot {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String
  location    String
  region      String
  type        String
  images      String[]
  activities  String[]
  bestTime    String?
  ticketPrice Float?
  rating      Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tourist_spots")
}

// Model for Hotels - simplified without relations
model Hotel {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  address     String
  city        String
  starRating  Int
  priceMin    Float
  priceMax    Float
  amenities   String[]
  images      String[]
  description String
  rating      Float    @default(0)
  latitude    Float?
  longitude   Float?
  contact     String?
  policies    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("hotels")
}

// Model for Rooms - without relations
model Room {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  hotelId     String
  type        String
  description String?
  price       Float
  basePrice   Float
  available   Int
  totalRooms  Int
  maxGuests   Int
  amenities   String[]
  images      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("rooms")
}

// Model for Room Pricing
model RoomPricing {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  roomId        String
  date          String
  price         Float
  isSpecial     Boolean  @default(false)
  specialReason String?

  @@map("room_pricing")
}

// Model for Room Availability
model RoomAvailability {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  roomId      String
  date        String
  available   Int
  booked      Int      @default(0)

  @@map("room_availability")
}

// Model for Hotel Reviews
model HotelReview {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  hotelId     String
  userId      String?
  userName    String
  userAvatar  String?
  rating      Int
  comment     String
  images      String[]
  response    String?
  respondedAt DateTime?
  createdAt   DateTime @default(now())

  @@map("hotel_reviews")
}

// Model for Restaurants
model Restaurant {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  address     String
  city        String
  cuisineType String
  priceRange  String
  style       String
  openTime    String
  closeTime   String
  images      String[]
  rating      Float    @default(0)
  latitude    Float?
  longitude   Float?
  contact     String?
  promotions  String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("restaurants")
}

model MenuItem {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  restaurantId String
  name         String
  description  String?
  price        Float
  category     String?
  image        String?
  createdAt    DateTime @default(now())

  @@map("menu_items")
}

// Model for Resorts
model Resort {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  address       String
  locationType  String
  starRating    Int
  priceMin      Float
  priceMax      Float
  resortType    String
  amenities     String[]
  images        String[]
  description   String
  activities    String[]
  rating        Float    @default(0)
  latitude      Float?
  longitude     Float?
  contact       String?
  packages      String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("resorts")
}

model ResortRoom {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  resortId   String
  type       String
  price      Float
  available  Int
  maxGuests  Int
  amenities  String[]
  images     String[]
  createdAt  DateTime @default(now())

  @@map("resort_rooms")
}

// Model for Transport
model Transport {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  type        String
  route       String
  company     String
  departure   String
  arrival     String
  schedule    String
  price       Float
  duration    String
  contact     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("transports")
}

// Model for Tour Packages
model TourPackage {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  description  String
  duration     String
  itinerary    String[]
  includes     String[]
  price        Float
  discount     Float?   @default(0)
  startDate    DateTime?
  endDate      DateTime?
  destinations String[]
  images       String[]
  rating       Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("tour_packages")
}

// Model for Promotions (F201-F210)
model Promotion {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  promoCode     String   @unique
  name          String
  description   String?
  discountPercent Float   // 0-100
  startDate     DateTime @map("start_date")
  endDate       DateTime @map("end_date")
  targetType    String?  // "Tour" | "Hotel" | "All"
  targetId      String?  // ID của Tour hoặc Hotel cụ thể (null = áp dụng cho tất cả)
  status        String   @default("active") // "active" | "inactive"
  isShowHome    Boolean  @default(false)  @map("is_show_home")
  createdAt     DateTime @default(now())   @map("created_at")
  updatedAt     DateTime @updatedAt

  @@map("promotions")
}

// Model for Contact/Feedback
model Contact {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  fullName    String
  email       String
  phone       String
  address     String?
  serviceType String?
  desiredDate DateTime?
  groupSize   Int?
  message     String
  rating      Int?
  title       String?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("contacts")
}

// Model for Company Information
model CompanyInfo {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  history     String
  vision      String
  mission     String
  services    String[]
  awards      String[]
  images      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("company_info")
}

model ContactDetail {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  companyInfoId  String       @unique
  address        String
  phone          String
  email          String
  website        String?
  workingHours   String
  createdAt      DateTime     @default(now())

  @@map("contact_details")
}

model SocialLink {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  contactDetailId String
  platform        String
  url             String
  createdAt       DateTime     @default(now())

  @@map("social_links")
}
